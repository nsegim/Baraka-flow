generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Business {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  phone           String?
  address         String?
  currency        String          @default("RWF")
  logoUrl         String?
  taxRate         Decimal         @default(0.18) @db.Decimal(5, 4)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  maxProducts     Int?
  maxUsers        Int?
  status          BusinessStatus  @default(ACTIVE)
  suspendedAt     DateTime?
  suspendedReason String?
  categories      Category[]
  creditNotes     CreditNote[]
  customers       Customer[]
  expenses        Expense[]
  notifications   Notification[]
  orders          Order[]
  products        Product[]
  purchaseOrders  PurchaseOrder[]
  suppliers       Supplier[]
  users           User[]
}

model User {
  id                 String          @id @default(cuid())
  name               String
  email              String          @unique
  password           String
  role               Role            @default(STAFF)
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  businessId         String
  creditNotesCreated CreditNote[]    @relation("CreditNoteCreator")
  expensesCreated    Expense[]       @relation("ExpenseCreator")
  orders             Order[]
  purchaseOrders     PurchaseOrder[] @relation("POCreator")
  stockMovements     StockMovement[]
  business           Business        @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model Customer {
  id                 String       @id @default(cuid())
  name               String
  phone              String?
  email              String?
  address            String?
  notes              String?
  outstandingBalance Decimal      @default(0) @db.Decimal(12, 2)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  businessId         String
  creditNotes        CreditNote[]
  business           Business     @relation(fields: [businessId], references: [id])
  orders             Order[]

  @@index([businessId])
  @@index([businessId, phone])
}

model Category {
  id         String    @id @default(cuid())
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])
  products   Product[]

  @@index([businessId])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  email          String?
  phone          String?
  country        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  businessId     String
  products       Product[]
  purchaseOrders PurchaseOrder[]
  business       Business        @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model Product {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  sku                String?
  price              Decimal             @db.Decimal(12, 2)
  costPrice          Decimal?            @db.Decimal(12, 2)
  stock              Int                 @default(0)
  minStock           Int                 @default(5)
  unit               String              @default("piece")
  imageUrl           String?
  origin             String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  businessId         String
  categoryId         String?
  supplierId         String?
  orderItems         OrderItem[]
  business           Business            @relation(fields: [businessId], references: [id])
  category           Category?           @relation(fields: [categoryId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]

  @@index([businessId])
  @@index([businessId, stock])
  @@index([businessId, categoryId])
  @@index([supplierId])
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  customerName   String
  customerPhone  String?
  status         OrderStatus   @default(PENDING)
  subtotal       Decimal?      @db.Decimal(12, 2)
  taxRate        Decimal?      @db.Decimal(5, 4)
  taxAmount      Decimal?      @db.Decimal(12, 2)
  discountAmount Decimal?      @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(UNPAID)
  notes          String?
  deliveredAt    DateTime?
  deliveryNotes  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  businessId     String
  userId         String
  customerId     String?
  business       Business      @relation(fields: [businessId], references: [id])
  customer       Customer?     @relation(fields: [customerId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  items          OrderItem[]
  payments       Payment[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, paymentStatus])
  @@index([businessId, createdAt])
  @@index([userId])
  @@index([customerId])
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id        String        @id @default(cuid())
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  reference String?
  notes     String?
  paidAt    DateTime      @default(now())
  createdAt DateTime      @default(now())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model StockMovement {
  id        String       @id @default(cuid())
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())
  productId String
  userId    String?
  product   Product      @relation(fields: [productId], references: [id])
  user      User?        @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([productId, createdAt])
  @@index([userId])
}

model Expense {
  id          String          @id @default(cuid())
  title       String
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory
  date        DateTime
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  businessId  String
  createdById String
  business    Business        @relation(fields: [businessId], references: [id])
  createdBy   User            @relation("ExpenseCreator", fields: [createdById], references: [id])

  @@index([businessId])
  @@index([businessId, date])
  @@index([businessId, category])
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String              @unique
  status       PurchaseOrderStatus @default(DRAFT)
  expectedDate DateTime?
  notes        String?
  totalCost    Decimal             @db.Decimal(12, 2)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  businessId   String
  supplierId   String
  createdById  String
  business     Business            @relation(fields: [businessId], references: [id])
  createdBy    User                @relation("POCreator", fields: [createdById], references: [id])
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]

  @@index([businessId])
  @@index([businessId, status])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  quantity         Int
  quantityReceived Int           @default(0)
  unitCost         Decimal       @db.Decimal(12, 2)
  purchaseOrderId  String
  productId        String
  product          Product       @relation(fields: [productId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

model CreditNote {
  id               String           @id @default(cuid())
  creditNoteNumber String           @unique
  amount           Decimal          @db.Decimal(12, 2)
  reason           String
  notes            String?
  status           CreditNoteStatus @default(ISSUED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  businessId       String
  customerId       String
  createdById      String
  business         Business         @relation(fields: [businessId], references: [id])
  createdBy        User             @relation("CreditNoteCreator", fields: [createdById], references: [id])
  customer         Customer         @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([customerId])
  @@index([businessId, createdAt])
}

model Notification {
  id         String           @id @default(cuid())
  type       NotificationType
  title      String
  message    String
  link       String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())
  businessId String
  business   Business         @relation(fields: [businessId], references: [id])

  @@index([businessId, isRead])
  @@index([businessId, createdAt])
}

enum NotificationType {
  NEW_ORDER
  ORDER_DELIVERED
  ORDER_CANCELLED
  LOW_STOCK
  PAYMENT_RECEIVED
  ORDER_RETURNED
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CREDIT
}

enum MovementType {
  IMPORT
  SALE
  ADJUSTMENT
  DAMAGE
  RETURN
}

enum ExpenseCategory {
  RENT
  UTILITIES
  TRANSPORT
  STAFF_WAGES
  MARKETING
  EQUIPMENT
  OTHER
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

enum CreditNoteStatus {
  ISSUED
  VOIDED
}
