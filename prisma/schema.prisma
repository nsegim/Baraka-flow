generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── SUBSCRIPTION PLAN (Global — defined by Super Admin) ──────────────────────

model Plan {
  id          String   @id @default(cuid())
  name        String   @unique               // "Free", "Starter", "Pro", "Enterprise"
  slug        String   @unique               // "free", "starter", "pro", "enterprise"
  description String?
  price       Decimal  @default(0) @db.Decimal(10, 2)
  currency    String   @default("RWF")
  maxUsers    Int?                            // null = unlimited
  maxProducts Int?                            // null = unlimited
  maxOrders   Int?                            // null = unlimited
  maxBranches Int?                            // null = unlimited
  features    Json     @default("{}")         // { "advancedReports": true, "apiAccess": false }
  isActive    Boolean  @default(true)
  isPublic    Boolean  @default(true)         // false = admin-assigned only
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businesses  Business[]

  @@index([isActive])
  @@index([slug])
}

// ── BUSINESS (Tenant root) ────────────────────────────────────────────────────

model Business {
  id                  String             @id @default(cuid())
  name                String
  email               String             @unique
  phone               String?
  address             String?
  currency            String             @default("RWF")
  language            String             @default("en")   // tenant default: en | fr | rw
  logoUrl             String?
  taxRate             Decimal            @default(0.18) @db.Decimal(5, 4)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  // ── Subscription ──────────────────────────────────────────────────────────
  planId              String?
  plan                String             @default("starter")  // legacy display field
  subscriptionStatus  SubscriptionStatus @default(TRIAL)
  trialEndsAt         DateTime?
  planExpiresAt       DateTime?          // kept for backward compat
  // ── Per-business limits (override plan limits when set) ───────────────────
  maxUsers            Int?
  maxProducts         Int?
  maxOrders           Int?
  maxBranches         Int?
  // ── Account status ────────────────────────────────────────────────────────
  status              BusinessStatus     @default(ACTIVE)
  suspendedAt         DateTime?
  suspendedReason     String?

  subscriptionPlan   Plan?              @relation(fields: [planId], references: [id], onDelete: SetNull)

  auditLogs          AuditLog[]
  attributeTemplates AttributeTemplate[]
  branches           Branch[]
  categories         Category[]
  creditNotes        CreditNote[]
  customers          Customer[]
  expenses           Expense[]
  notifications      Notification[]
  orders             Order[]
  products           Product[]
  purchaseOrders     PurchaseOrder[]
  supplierPayments   SupplierPayment[]
  suppliers          Supplier[]
  supportSessions    SupportSession[]
  users              User[]
}

// ── BRANCH ────────────────────────────────────────────────────────────────────

model Branch {
  id         String   @id @default(cuid())
  name       String                        // "Kigali City Branch"
  code       String                        // "KGL" — used in order/PO numbers
  address    String?
  phone      String?
  isActive   Boolean  @default(true)
  isDefault  Boolean  @default(false)     // true for the first/main branch
  businessId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business          Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  users             BranchUser[]
  inventory         BranchInventory[]
  orders            Order[]
  expenses          Expense[]
  purchaseOrders    PurchaseOrder[]
  customers         Customer[]
  stockMovements    StockMovement[]
  transfersOut      StockTransfer[]   @relation("TransferFrom")
  transfersIn       StockTransfer[]   @relation("TransferTo")
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@unique([businessId, code])
  @@index([businessId])
  @@index([businessId, isActive])
}

// ── BRANCH USER (junction: User ↔ Branch) ────────────────────────────────────

model BranchUser {
  id         String   @id @default(cuid())
  userId     String
  branchId   String
  assignedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

// ── BRANCH INVENTORY (stock per product per branch) ───────────────────────────

model BranchInventory {
  id        String @id @default(cuid())
  branchId  String
  productId String
  stock     Int    @default(0)
  minStock  Int    @default(5)

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
  @@index([branchId])
  @@index([branchId, stock])
  @@index([productId])
}

// ── STOCK TRANSFER (branch-to-branch) ────────────────────────────────────────

model StockTransfer {
  id            String              @id @default(cuid())
  fromBranchId  String
  toBranchId    String
  productId     String
  quantity      Int
  notes         String?
  status        StockTransferStatus @default(PENDING)
  requestedById String
  approvedById  String?
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  businessId    String

  fromBranch  Branch  @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch    Branch  @relation("TransferTo",   fields: [toBranchId],   references: [id])
  product     Product @relation(fields: [productId], references: [id])
  requestedBy User    @relation("TransfersRequested", fields: [requestedById], references: [id])
  approvedBy  User?   @relation("TransfersApproved",  fields: [approvedById],  references: [id])

  @@index([businessId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([businessId, status])
}

// ── USER ──────────────────────────────────────────────────────────────────────

model User {
  id                 String          @id @default(cuid())
  name               String
  email              String          @unique
  password           String
  role               Role            @default(STAFF)
  language           String?                        // user override: en | fr | rw | null = use business default
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  businessId         String

  auditLogs               AuditLog[]
  branchAssignments       BranchUser[]
  creditNotesCreated      CreditNote[]      @relation("CreditNoteCreator")
  expensesCreated         Expense[]         @relation("ExpenseCreator")
  orders                  Order[]
  purchaseOrders          PurchaseOrder[]   @relation("POCreator")
  stockMovements          StockMovement[]
  supplierPayments        SupplierPayment[]
  transfersRequested      StockTransfer[]   @relation("TransfersRequested")
  transfersApproved       StockTransfer[]   @relation("TransfersApproved")
  business                Business          @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

// ── CUSTOMER ──────────────────────────────────────────────────────────────────

model Customer {
  id                  String       @id @default(cuid())
  name                String
  phone               String?
  email               String?
  address             String?
  notes               String?
  outstandingBalance  Decimal      @default(0) @db.Decimal(12, 2)
  defaultPaymentTerms String       @default("COD")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  businessId          String
  branchId            String?      // null = shared across all branches

  creditNotes CreditNote[]
  business    Business     @relation(fields: [businessId], references: [id])
  branch      Branch?      @relation(fields: [branchId], references: [id])
  orders      Order[]

  @@index([businessId])
  @@index([businessId, branchId])
  @@index([businessId, phone])
}

// ── CATEGORY ──────────────────────────────────────────────────────────────────

model Category {
  id         String    @id @default(cuid())
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  businessId String

  business           Business            @relation(fields: [businessId], references: [id])
  products           Product[]
  attributeTemplates AttributeTemplate[]

  @@index([businessId])
}

// ── SUPPLIER ──────────────────────────────────────────────────────────────────

model Supplier {
  id                 String            @id @default(cuid())
  name               String
  email              String?
  phone              String?
  country            String?
  outstandingBalance Decimal           @default(0) @db.Decimal(12, 2)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  businessId         String

  products         Product[]
  purchaseOrders   PurchaseOrder[]
  supplierPayments SupplierPayment[]
  business         Business          @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

// ── PRODUCT (catalog — shared across branches; stock lives in BranchInventory) ─

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?
  price       Decimal  @db.Decimal(12, 2)
  costPrice   Decimal? @db.Decimal(12, 2)
  unit        String   @default("piece")
  imageUrl    String?
  origin      String?
  attributes  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  businessId  String
  categoryId  String?
  supplierId  String?

  orderItems         OrderItem[]
  business           Business                @relation(fields: [businessId], references: [id])
  category           Category?               @relation(fields: [categoryId], references: [id])
  supplier           Supplier?               @relation(fields: [supplierId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]
  inventory          BranchInventory[]
  stockTransfers     StockTransfer[]
  attributeValues    ProductAttributeValue[]

  @@index([businessId])
  @@index([businessId, categoryId])
  @@index([supplierId])
}

// ── ORDER ─────────────────────────────────────────────────────────────────────

model Order {
  id             String        @id @default(cuid())
  orderNumber    String
  customerName   String
  customerPhone  String?
  status         OrderStatus   @default(PENDING)
  subtotal       Decimal?      @db.Decimal(12, 2)
  taxRate        Decimal?      @db.Decimal(5, 4)
  taxAmount      Decimal?      @db.Decimal(12, 2)
  discountAmount Decimal?      @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(UNPAID)
  paymentTerms   String        @default("COD")
  dueDate        DateTime?
  notes          String?
  deliveredAt    DateTime?
  deliveryNotes  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  businessId     String
  branchId       String
  userId         String
  customerId     String?

  business  Business    @relation(fields: [businessId], references: [id])
  branch    Branch      @relation(fields: [branchId], references: [id])
  customer  Customer?   @relation(fields: [customerId], references: [id])
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
  payments  Payment[]

  @@unique([orderNumber, branchId])
  @@index([businessId])
  @@index([businessId, branchId])
  @@index([businessId, branchId, status])
  @@index([businessId, branchId, paymentStatus])
  @@index([businessId, branchId, createdAt])
  @@index([branchId])
  @@index([userId])
  @@index([customerId])
}

// ── ORDER ITEM ────────────────────────────────────────────────────────────────

model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  costPrice Decimal? @db.Decimal(12, 2)
  orderId   String
  productId String

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ── PAYMENT ───────────────────────────────────────────────────────────────────

model Payment {
  id        String        @id @default(cuid())
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  reference String?
  notes     String?
  paidAt    DateTime      @default(now())
  createdAt DateTime      @default(now())
  orderId   String

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

// ── STOCK MOVEMENT ────────────────────────────────────────────────────────────

model StockMovement {
  id        String       @id @default(cuid())
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())
  productId String
  branchId  String
  userId    String?

  product Product  @relation(fields: [productId], references: [id])
  branch  Branch   @relation(fields: [branchId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([branchId])
  @@index([productId, createdAt])
  @@index([branchId, createdAt])
  @@index([userId])
}

// ── EXPENSE ───────────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  title       String
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory
  date        DateTime
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  businessId  String
  branchId    String
  createdById String

  business  Business  @relation(fields: [businessId], references: [id])
  branch    Branch    @relation(fields: [branchId], references: [id])
  createdBy User     @relation("ExpenseCreator", fields: [createdById], references: [id])

  @@index([businessId])
  @@index([businessId, branchId])
  @@index([businessId, branchId, date])
  @@index([businessId, category])
}

// ── PURCHASE ORDER ────────────────────────────────────────────────────────────

model PurchaseOrder {
  id            String              @id @default(cuid())
  poNumber      String
  status        PurchaseOrderStatus @default(DRAFT)
  expectedDate  DateTime?
  notes         String?
  totalCost     Decimal             @db.Decimal(12, 2)
  amountPaid    Decimal             @default(0) @db.Decimal(12, 2)
  paymentStatus PaymentStatus       @default(UNPAID)
  invoiceNumber String?
  invoiceDate   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  businessId    String
  branchId      String
  supplierId    String
  createdById   String

  business         Business            @relation(fields: [businessId], references: [id])
  branch           Branch              @relation(fields: [branchId], references: [id])
  createdBy        User                @relation("POCreator", fields: [createdById], references: [id])
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
  items            PurchaseOrderItem[]
  supplierPayments SupplierPayment[]

  @@unique([poNumber, branchId])
  @@index([businessId])
  @@index([businessId, branchId])
  @@index([businessId, branchId, status])
}

// ── PURCHASE ORDER ITEM ───────────────────────────────────────────────────────

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  quantity         Int
  quantityReceived Int           @default(0)
  unitCost         Decimal       @db.Decimal(12, 2)
  purchaseOrderId  String
  productId        String

  product       Product       @relation(fields: [productId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

// ── CREDIT NOTE ───────────────────────────────────────────────────────────────

model CreditNote {
  id               String           @id @default(cuid())
  creditNoteNumber String           @unique
  amount           Decimal          @db.Decimal(12, 2)
  reason           String
  notes            String?
  status           CreditNoteStatus @default(ISSUED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  businessId       String
  customerId       String
  createdById      String

  business    Business @relation(fields: [businessId], references: [id])
  createdBy   User     @relation("CreditNoteCreator", fields: [createdById], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([customerId])
  @@index([businessId, createdAt])
}

// ── SUPPLIER PAYMENT ──────────────────────────────────────────────────────────

model SupplierPayment {
  id              String        @id @default(cuid())
  amount          Decimal       @db.Decimal(12, 2)
  method          PaymentMethod
  reference       String?
  notes           String?
  paidAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())
  businessId      String
  supplierId      String
  purchaseOrderId String?
  createdById     String

  business      Business       @relation(fields: [businessId], references: [id])
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  createdBy     User           @relation(fields: [createdById], references: [id])

  @@index([supplierId])
  @@index([businessId])
  @@index([purchaseOrderId])
}

// ── NOTIFICATION ──────────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  type       NotificationType
  title      String
  message    String
  link       String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())
  businessId String
  branchId   String?          // null = business-wide notification

  business Business @relation(fields: [businessId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])

  @@index([businessId, isRead])
  @@index([businessId, createdAt])
  @@index([businessId, branchId])
}

// ── PASSWORD RESET ────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// ── AUDIT LOG ─────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())
  businessId String
  branchId   String?     // null = business-wide action
  userId     String?

  business Business @relation(fields: [businessId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([businessId, createdAt])
  @@index([businessId, branchId])
  @@index([businessId, action])
  @@index([entityType, entityId])
}

// ── ENUMS ─────────────────────────────────────────────────────────────────────

enum NotificationType {
  NEW_ORDER
  ORDER_DELIVERED
  ORDER_CANCELLED
  LOW_STOCK
  PAYMENT_RECEIVED
  ORDER_RETURNED
  STOCK_TRANSFER
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CREDIT
}

enum MovementType {
  IMPORT
  SALE
  ADJUSTMENT
  DAMAGE
  RETURN
  TRANSFER_IN
  TRANSFER_OUT
}

enum ExpenseCategory {
  RENT
  UTILITIES
  TRANSPORT
  STAFF_WAGES
  MARKETING
  EQUIPMENT
  OTHER
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

enum CreditNoteStatus {
  ISSUED
  VOIDED
}

enum StockTransferStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum AuditAction {
  // Orders
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  ORDER_DELETED
  ORDER_RETURNED
  // Payments
  PAYMENT_RECORDED
  // Products & stock
  PRODUCT_CREATED
  PRODUCT_DELETED
  STOCK_ADJUSTED
  // Purchase orders
  PURCHASE_ORDER_CREATED
  GOODS_RECEIVED
  SUPPLIER_PAYMENT_RECORDED
  // Users
  USER_CREATED
  USER_ROLE_CHANGED
  USER_DEACTIVATED
  USER_DELETED
  // Financial
  CREDIT_NOTE_ISSUED
  EXPENSE_CREATED
  // Business
  BUSINESS_SETTINGS_CHANGED
  // Branches
  BRANCH_CREATED
  BRANCH_UPDATED
  BRANCH_USER_ASSIGNED
  BRANCH_USER_REMOVED
  // Stock transfers
  STOCK_TRANSFER_REQUESTED
  STOCK_TRANSFER_APPROVED
  STOCK_TRANSFER_COMPLETED
  STOCK_TRANSFER_REJECTED
  // Auth
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  // Product attributes
  ATTRIBUTE_TEMPLATE_CREATED
  ATTRIBUTE_TEMPLATE_UPDATED
  // Subscription
  SUBSCRIPTION_CHANGED
}

// ── FLEXIBLE PRODUCT ATTRIBUTES ───────────────────────────────────────────────

// Tenant-defined attribute schema (what attributes exist for products in this business/category)
model AttributeTemplate {
  id         String        @id @default(cuid())
  name       String                              // Display name: "Color", "Storage", "Weight"
  key        String                              // Machine key: "color", "storage_gb", "weight_kg"
  type       AttributeType @default(TEXT)
  options    Json?                               // For SELECT type: ["Red", "Blue", "Green"]
  unit       String?                             // Display unit: "kg", "cm", "GB"
  isRequired Boolean       @default(false)
  sortOrder  Int           @default(0)
  isActive   Boolean       @default(true)
  businessId String
  categoryId String?                             // null = applies to all products in this business

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business        Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category        Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  attributeValues ProductAttributeValue[]

  @@index([businessId])
  @@index([businessId, categoryId])
  @@index([businessId, isActive])
}

// Per-product attribute values (what value does this product have for each template)
model ProductAttributeValue {
  id                  String @id @default(cuid())
  productId           String
  attributeTemplateId String
  value               String @db.VarChar(1000)

  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeTemplate AttributeTemplate @relation(fields: [attributeTemplateId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeTemplateId])
  @@index([productId])
  @@index([attributeTemplateId])
  @@index([attributeTemplateId, value])
}

enum AttributeType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
}

// ── PLATFORM LAYER ────────────────────────────────────────────────────────────

model PlatformUser {
  id        String       @id @default(cuid())
  name      String
  email     String       @unique
  password  String
  role      PlatformRole @default(SUPPORT)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  supportSessions   SupportSession[]
  platformAuditLogs PlatformAuditLog[]
}

model SupportSession {
  id             String               @id @default(cuid())
  platformUserId String
  businessId     String
  justification  String
  accessScope    SupportAccessScope
  status         SupportSessionStatus @default(ACTIVE)
  expiresAt      DateTime
  endedAt        DateTime?
  ipAddress      String?
  createdAt      DateTime             @default(now())

  platformUser PlatformUser    @relation(fields: [platformUserId], references: [id])
  business     Business        @relation(fields: [businessId], references: [id])
  actions      SupportAction[]

  @@index([businessId])
  @@index([platformUserId])
  @@index([status, expiresAt])
}

model SupportAction {
  id               String   @id @default(cuid())
  supportSessionId String
  action           String
  entityType       String?
  entityId         String?
  metadata         Json?
  ipAddress        String?
  createdAt        DateTime @default(now())

  session SupportSession @relation(fields: [supportSessionId], references: [id])

  @@index([supportSessionId])
}

model PlatformAuditLog {
  id             String         @id @default(cuid())
  platformUserId String?
  action         PlatformAction
  entityType     String?
  entityId       String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime       @default(now())

  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id])

  @@index([platformUserId])
  @@index([entityId])
  @@index([createdAt])
}

enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
}

enum SupportAccessScope {
  READ_ONLY
  FULL_IMPERSONATION
}

enum SupportSessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ENDED
}

enum PlatformAction {
  TENANT_CREATED
  TENANT_SUSPENDED
  TENANT_UNSUSPENDED
  TENANT_DELETED
  TENANT_PLAN_CHANGED
  PLATFORM_USER_CREATED
  PLATFORM_USER_DEACTIVATED
  PASSWORD_RESET_INITIATED
  SUPPORT_SESSION_OPENED
